<%- include('base', {
  title: '运行日志',
  body: `
<h3 class="mb-3"><i class="bi bi-journal-text"></i> 运行日志</h3>

<div class="row g-3 mb-3">
    <div class="col-md-2">
        <select class="form-select" id="logLevel" onchange="loadLogs()">
            <option value="">全部级别</option>
            <option value="error">ERROR</option>
            <option value="warn">WARN</option>
            <option value="info">INFO</option>
            <option value="debug">DEBUG</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-primary w-100" onclick="loadLogs()"><i class="bi bi-arrow-clockwise"></i> 刷新</button>
    </div>
    <div class="col-md-8 text-end">
        <a href="/api/logs/export" class="btn btn-outline-success"><i class="bi bi-download"></i> 导出日志</a>
        <button class="btn btn-outline-danger" onclick="clearLogDisplay()"><i class="bi bi-trash"></i> 清空显示</button>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span><i class="bi bi-list-ul"></i> 日志列表</span>
        <small class="text-muted" id="logCount">0 条</small>
    </div>
    <div class="card-body p-0">
        <div id="logContainer" style="max-height: 600px; overflow-y: auto; font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: 0.8rem; line-height: 1.5;">
            <div class="text-center text-muted py-4">加载中...</div>
        </div>
    </div>
</div>

<script>
let autoRefresh = null;

function colorForLevel(level) {
    switch(level) {
        case 'ERROR': return 'danger';
        case 'WARN': return 'warning';
        case 'INFO': return 'info';
        case 'DEBUG': return 'secondary';
        default: return 'light';
    }
}

async function loadLogs() {
    const level = document.getElementById('logLevel').value;
    const limit = 500;
    let url = '/api/logs?limit=' + limit;
    if (level) url += '&level=' + level;
    
    const res = await fetch(url);
    const data = await res.json();
    
    document.getElementById('logCount').textContent = data.total + ' 条 (显示 ' + data.lines.length + ')';
    
    const container = document.getElementById('logContainer');
    if (data.lines.length === 0) {
        container.innerHTML = '<div class="text-center text-muted py-4">暂无日志</div>';
        return;
    }
    
    let html = '<table class="table table-sm table-hover mb-0" style="font-size:0.78rem;">';
    html += '<thead class="table-light"><tr><th>时间</th><th>级别</th><th>模块</th><th>消息</th></tr></thead><tbody>';
    
    data.lines.forEach(line => {
        html += '<tr>';
        html += '<td class="text-nowrap"><small>' + line.time + '</small></td>';
        html += '<td><span class="badge bg-' + colorForLevel(line.level) + ' badge-sm" style="font-size:0.65rem;">' + line.level + '</span></td>';
        html += '<td><small class="text-muted">' + line.category + '</small></td>';
        html += '<td><small>' + (line.message || '') + '</small></td>';
        html += '</tr>';
    });
    
    html += '</tbody></table>';
    container.innerHTML = html;
    container.scrollTop = container.scrollHeight;
}

function clearLogDisplay() {
    document.getElementById('logContainer').innerHTML = '<div class="text-center text-muted py-4">已清空（下次刷新重新加载）</div>';
}

loadLogs();
setInterval(loadLogs, 10000);
</script>
`}) %>
